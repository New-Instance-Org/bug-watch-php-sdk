{
    "name": "newinstance/bugwatch-php",
    "description": "BugWatch SDK for capturing logs, errors, and runtime context from PHP applications.",
    "type": "library",
    "license": "MIT",
    "keywords": ["bugwatch", "sdk", "logging", "errors", "observability", "psr-3"],
    "require": {
        "php": "^8.2",
        "psr/log": "^3",
        "psr/http-client": "^1",
        "psr/http-factory": "^1",
        "psr/http-message": "^1 || ^2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^1.12",
        "friendsofphp/php-cs-fixer": "^3.64",
        "guzzlehttp/guzzle": "^7.9"
    },
    "suggest": {
        "ext-curl": "Default zero-config HTTP transport"
    },
    "autoload": {
        "psr-4": { "NewInstance\\BugWatch\\": "src/" },
        "files": ["src/functions.php"]
    },
    "autoload-dev": {
        "psr-4": { "NewInstance\\BugWatch\\Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": { "sort-packages": true }
}
